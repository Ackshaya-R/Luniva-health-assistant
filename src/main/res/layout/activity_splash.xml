<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:background="@drawable/bg_gradient_light">

    <ImageView
        android:layout_width="90dp" android:layout_height="90dp"
        android:src="@mipmap/ic_launcher" android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/app_name" android:textSize="34sp"
        android:textStyle="bold" android:textColor="@color/primary_blue"/>

    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/tagline" android:textSize="14sp"
        android:textColor="@color/text_medium" android:layout_marginTop="12dp"/>
</LinearLayout>
